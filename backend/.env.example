# ============================================
# ERP SYSTEM - ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and fill in the values
# NEVER commit .env to version control!

# MySQL (Direct Connection)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=erp

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=30d

# Server
PORT=3000
NODE_ENV=development

# Khôi phục mật khẩu Super Admin khi quên (POST /api/auth/super-admin-recovery + trang /super-admin-recovery)
# Đặt chuỗi ngẫu nhiên dài; KHÔNG commit giá trị thật. Hoặc dùng script: node backend/scripts/resetSuperAdminPassword.js
# SUPERADMIN_RESET_KEY=
