# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# URL gốc của frontend (vd. https://erp.example.com) — dùng cho og:image / chia sẻ link (ảnh xem trước).
# Nếu đặt, build sẽ chèn URL tuyệt đối cho Open Graph. Có thể trùng APP_URL khi deploy một domain.
# VITE_SITE_URL="https://erp.example.com"

# Khi mở web bằng IP LAN (vd. http://192.168.1.104:5173) mà trắng/lỗi HMR: đặt đúng IP máy dev (ipconfig).
# VITE_DEV_HMR_HOST=192.168.1.104
#
# iPhone Safari “không vào được” sau khi cập nhật npm: thử http://<IP-máy-tính>:5173 (không dùng localhost trên điện thoại),
# cùng Wi‑Fi, firewall cho cổng 5173; vite.config đã bật allowedHosts cho dev.
